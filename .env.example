# App
NEXT_PUBLIC_APP_NAME=CodePilot AI

# FastAPI backend URL (used by Next.js API proxy routes)
FASTAPI_BASE_URL=http://localhost:8000

# OpenAI-compatible API (supports Claude via OpenAI-compatible base URL)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Judge0 code execution
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
# RapidAPI key (get yours at https://rapidapi.com/judge0-official/api/judge0-ce)
X_RAPIDAPI_KEY=

# Postgres (scaffolded for future use)
POSTGRES_USER=interviewcoach
POSTGRES_PASSWORD=changeme
POSTGRES_DB=interviewcoach

# Redis (scaffolded for future use)
REDIS_URL=redis://localhost:6379
